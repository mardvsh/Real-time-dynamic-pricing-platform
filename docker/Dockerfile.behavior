FROM golang:1.24-alpine AS builder
WORKDIR /app
COPY go.mod go.sum* ./
RUN go mod download || true
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -o /bin/behavior ./services/behavior-service/cmd/behavior

FROM gcr.io/distroless/static-debian12
COPY --from=builder /bin/behavior /behavior
EXPOSE 8082
ENTRYPOINT ["/behavior"]
